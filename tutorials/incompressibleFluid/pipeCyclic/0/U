FoamFile
{
    format      ascii;
    class       volVectorField;
    location    "0";
    object      U;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

dimensions      [0 1 -1 0 0 0 0];

internalField
{
    type        coded;

    evaluate
    #{
        field = velocity(1, 0, 0) + (C ^ rate(2, 0, 0));
    #};
}

boundaryField
{
    #includeEtc "caseDicts/setConstraintTypes"

    inlet
    {
        type           functionalFixedValue;

        function
        {
            $internalField;
        }
    }

    outlet
    {
        type            pressureInletOutletVelocity;
        value           uniform (1 0 0);
    }

    walls
    {
        type            noSlip;
    }
}


